{
  "name": "@familyclaw/user-app",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "stylelint": "16.10.0"
  },
  "scripts": {
    "clean:generated-js": "node ./scripts/clean-generated-js.mjs",
    "check:style-guard": "node ./scripts/check-style-guard.mjs",
    "predev:h5": "npm run clean:generated-js",
    "dev:h5": "taro build --type h5 --watch",
    "prebuild:h5": "npm run clean:generated-js",
    "build:h5": "taro build --type h5",
    "prebuild:rn": "npm run clean:generated-js",
    "build:rn": "taro build --type rn",
    "build:ios": "npm run build:rn",
    "build:android": "npm run build:rn",
    "prebuild:harmony": "npm run clean:generated-js",
    "build:harmony": "taro build --type harmony_cpp",
    "pretypecheck": "npm run clean:generated-js && npm run check:style-guard",
    "typecheck": "tsc --noEmit",
    "test:voiceprint": "powershell -NoProfile -Command \"Remove-Item -Recurse -Force '.tmp/voiceprint-tests' -ErrorAction SilentlyContinue; & '.\\node_modules\\.bin\\tsc.cmd' -p tsconfig.voiceprint-tests.json; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; node --test '.tmp/voiceprint-tests/settings/components/__tests__/speakerVoiceprintHelpers.test.js' '.tmp/voiceprint-tests/settings/components/__tests__/speakerVoiceprintComponents.test.js'\""
  },
  "dependencies": {
    "@familyclaw/user-core": "file:../../packages/user-core",
    "@familyclaw/user-platform": "file:../../packages/user-platform",
    "@familyclaw/user-testing": "file:../../packages/user-testing",
    "@familyclaw/user-ui": "file:../../packages/user-ui",
    "@react-native-community/slider": "4.4.2",
    "@react-native-picker/picker": "2.6.1",
    "@react-native/metro-config": "^0.73.2",
    "@tarojs/components": "4.1.11",
    "@tarojs/components-rn": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/rn-runner": "4.1.11",
    "@tarojs/rn-supporter": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/runtime-rn": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "@tarojs/taro-rn": "4.1.11",
    "@tarojs/webpack5-runner": "^4.1.11",
    "expo": "~50.0.0",
    "expo-av": "~13.10.6",
    "expo-camera": "~14.1.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "^0.73.1",
    "react-native-device-info": "^14.0.0",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-pager-view": "6.2.3",
    "react-native-root-siblings": "^5.0.0",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "14.1.0",
    "react-native-webview": "13.6.4"
  },
  "devDependencies": {
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@tarojs/cli": "4.1.11",
    "@tarojs/plugin-framework-react": "4.1.11",
    "@tarojs/plugin-platform-h5": "4.1.11",
    "@tarojs/plugin-platform-harmony-cpp": "4.1.11",
    "@tarojs/vite-runner": "4.1.11",
    "babel-preset-taro": "4.1.11",
    "metro-react-native-babel-preset": "0.73.10",
    "react-refresh": "^0.18.0",
    "stylelint": "16.10.0",
    "typescript": "^5.7.3",
    "webpack": "5.91.0"
  }
}
