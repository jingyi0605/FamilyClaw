FAMILYCLAW_DATABASE_URL=sqlite:///./data/familyclaw.db
FAMILYCLAW_HOME_ASSISTANT_BASE_URL=http://127.0.0.1:8123
FAMILYCLAW_HOME_ASSISTANT_TOKEN=replace-with-your-token
FAMILYCLAW_HOME_ASSISTANT_TIMEOUT_SECONDS=10
FAMILYCLAW_AI_GATEWAY_ENABLED=true
FAMILYCLAW_AI_DEFAULT_PROVIDER_CODE=local-ollama
FAMILYCLAW_AI_DEFAULT_FALLBACK_PROVIDER_CODES=["openai-primary"]
FAMILYCLAW_AI_DEFAULT_TIMEOUT_MS=15000
FAMILYCLAW_AI_DEFAULT_MAX_RETRY_COUNT=1
FAMILYCLAW_AI_DEFAULT_ROUTING_MODE=primary_then_fallback
FAMILYCLAW_AI_DEFAULT_ALLOW_REMOTE=true
FAMILYCLAW_AI_LOCAL_PREFERRED=false
FAMILYCLAW_AI_SECRET_REF_PREFIX=env://
FAMILYCLAW_AI_PROVIDER_CONFIGS={"local-ollama":{"enabled":true,"transport_type":"local_gateway","base_url":"http://127.0.0.1:11434","timeout_ms":20000,"allow_remote":false,"secret_env_var":null,"extra":{"family":"ollama"}},"openai-primary":{"enabled":false,"transport_type":"openai_compatible","base_url":"https://api.openai.com/v1","timeout_ms":15000,"allow_remote":true,"secret_env_var":"OPENAI_API_KEY","extra":{"family":"openai"}}}
OPENAI_API_KEY=replace-with-real-secret
