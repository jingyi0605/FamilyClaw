{
  "id": "homeassistant",
  "name": "Home Assistant 插件",
  "version": "0.1.0",
  "types": ["action", "connector", "memory-ingestor"],
  "permissions": [
    "device.control",
    "device.read",
    "memory.write.device",
    "memory.write.observation"
  ],
  "risk_level": "medium",
  "triggers": ["manual", "schedule"],
  "entrypoints": {
    "action": "app.plugins.builtin.homeassistant_device_action.executor.run",
    "connector": "app.plugins.builtin.homeassistant_device_action.connector.sync",
    "memory_ingestor": "app.plugins.builtin.homeassistant_device_action.ingestor.transform"
  }
}
