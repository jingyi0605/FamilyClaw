{
  "id": "builtin.provider.ollama",
  "name": "Ollama",
  "version": "1.0.0",
  "types": ["ai-provider"],
  "permissions": [],
  "risk_level": "low",
  "triggers": [],
  "entrypoints": {
    "ai_provider": "app.plugins.builtin.ai_provider_ollama.driver.build_driver"
  },
  "capabilities": {
    "ai_provider": {
      "adapter_code": "ollama",
      "display_name": "Ollama",
      "branding": {
        "logo_resource": "resources/logo.png",
        "logo_resource_dark": "resources/logo.png",
        "description_resource": "resources/description.json"
      },
      "field_schema": [
        { "key": "display_name", "label": "Display Name", "field_type": "text", "required": true, "placeholder": "Ollama Main", "options": [] },
        { "key": "provider_code", "label": "Provider Code", "field_type": "text", "required": true, "placeholder": "family-ollama-main", "options": [] },
        { "key": "base_url", "label": "Base URL", "field_type": "text", "required": false, "placeholder": "http://127.0.0.1:11434/v1", "help_text": "Default local OpenAI-compatible endpoint for Ollama.", "default_value": "http://127.0.0.1:11434/v1", "options": [] },
        { "key": "secret_ref", "label": "Secret Reference", "field_type": "secret", "required": false, "placeholder": "ollama", "help_text": "The compatibility layer accepts an API key placeholder, but Ollama usually ignores it.", "options": [] },
        { "key": "model_name", "label": "Model Name", "field_type": "text", "required": true, "placeholder": "llama3.2", "options": [] },
        {
          "key": "privacy_level",
          "label": "Privacy Level",
          "field_type": "select",
          "required": true,
          "default_value": "local_only",
          "options": [
            { "label": "Local Only", "value": "local_only" }
          ]
        },
        { "key": "latency_budget_ms", "label": "Latency Budget (ms)", "field_type": "number", "required": false, "placeholder": "60000", "default_value": 60000, "options": [] }
      ],
      "config_ui": {
        "field_order": ["display_name", "base_url", "secret_ref", "model_name", "privacy_level", "latency_budget_ms"],
        "sections": [
          {
            "key": "connection",
            "title": "Connection",
            "description": "Enter the local Ollama endpoint and the optional API key placeholder.",
            "fields": ["display_name", "base_url", "secret_ref"]
          },
          {
            "key": "model",
            "title": "Model",
            "description": "You can discover pulled Ollama models before saving.",
            "fields": ["model_name", "privacy_level", "latency_budget_ms"]
          }
        ],
        "actions": [
          {
            "key": "discover_models",
            "label": "Refresh Models",
            "description": "Read available models from the current Ollama service.",
            "kind": "model_discovery",
            "placement": "field",
            "field_key": "model_name"
          }
        ]
      },
      "model_discovery": {
        "enabled": true,
        "action_key": "discover_models",
        "depends_on_fields": ["base_url"],
        "target_field": "model_name",
        "debounce_ms": 500,
        "empty_state_text": "No models were found. Pull a model in Ollama first.",
        "discovery_hint_text": "The model list refreshes automatically after the endpoint is filled in.",
        "discovering_text": "Loading Ollama models...",
        "discovered_text_template": "Discovered {count} Ollama models."
      },
      "supported_model_types": ["llm"],
      "llm_workflow": "openai_chat_completions",
      "runtime_capability": {
        "transport_type": "local_gateway",
        "api_family": "openai_chat_completions",
        "default_privacy_level": "local_only",
        "default_supported_capabilities": ["text"],
        "supports_model_discovery": true
      }
    }
  },
  "compatibility": {
    "provider_profile_schema_version": 1,
    "transport_type": "local_gateway",
    "api_family": "openai_chat_completions",
    "description": "Local Ollama service using the OpenAI-compatible endpoint and automatic model discovery."
  }
}
