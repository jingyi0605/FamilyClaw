{
  "id": "builtin.provider.openrouter",
  "name": "OpenRouter",
  "version": "1.0.0",
  "types": ["ai-provider"],
  "permissions": [],
  "risk_level": "low",
  "triggers": [],
  "entrypoints": {
    "ai_provider": "app.plugins.builtin.ai_provider_openrouter.driver.build_driver"
  },
  "capabilities": {
    "ai_provider": {
      "adapter_code": "openrouter",
      "display_name": "OpenRouter",
      "branding": {
        "logo_resource": "resources/logo.svg",
        "logo_resource_dark": "resources/logo.svg",
        "description_resource": "resources/description.json"
      },
      "field_schema": [
        { "key": "display_name", "label": "Display Name", "field_type": "text", "required": true, "placeholder": "OpenRouter Main", "options": [] },
        { "key": "provider_code", "label": "Provider Code", "field_type": "text", "required": true, "placeholder": "family-openrouter-main", "options": [] },
        { "key": "base_url", "label": "Base URL", "field_type": "text", "required": false, "placeholder": "https://openrouter.ai/api/v1", "help_text": "Defaults to the common official endpoint. Change it only when you use a proxy or gateway.", "default_value": "https://openrouter.ai/api/v1", "options": [] },
        { "key": "secret_ref", "label": "Secret Reference", "field_type": "secret", "required": true, "placeholder": "OPENROUTER_API_KEY", "options": [] },
        { "key": "model_name", "label": "Model Name", "field_type": "text", "required": true, "placeholder": "openai/gpt-4o-mini", "default_value": "openai/gpt-4o-mini", "options": [] },
        {
          "key": "privacy_level",
          "label": "Privacy Level",
          "field_type": "select",
          "required": true,
          "default_value": "public_cloud",
          "options": [
            { "label": "Public Cloud", "value": "public_cloud" },
            { "label": "Private Cloud", "value": "private_cloud" }
          ]
        },
        { "key": "latency_budget_ms", "label": "Latency Budget (ms)", "field_type": "number", "required": false, "placeholder": "15000", "options": [] },
        { "key": "site_url", "label": "Site URL", "field_type": "text", "required": false, "placeholder": "https://familyclaw.local", "help_text": "Optional. Sent as HTTP-Referer for OpenRouter requests.", "options": [] },
        { "key": "app_name", "label": "App Name", "field_type": "text", "required": false, "placeholder": "FamilyClaw", "help_text": "Optional. Sent as X-Title for OpenRouter requests.", "options": [] }
      ],
      "config_ui": {
        "field_order": ["display_name", "base_url", "secret_ref", "site_url", "app_name", "model_name", "privacy_level", "latency_budget_ms"],
        "sections": [
          {
            "key": "connection",
            "title": "Connection",
            "description": "Enter the OpenRouter endpoint and API key.",
            "fields": ["display_name", "base_url", "secret_ref"]
          },
          {
            "key": "attribution",
            "title": "Attribution",
            "description": "These fields are forwarded as OpenRouter request headers.",
            "fields": ["site_url", "app_name"]
          },
          {
            "key": "model",
            "title": "Model",
            "description": "Choose the default model, privacy level, and latency budget.",
            "fields": ["model_name", "privacy_level", "latency_budget_ms"]
          }
        ],
        "actions": []
      },
      "model_discovery": {
        "enabled": false,
        "action_key": null,
        "depends_on_fields": [],
        "target_field": null,
        "debounce_ms": 500,
        "empty_state_text": null,
        "discovery_hint_text": null,
        "discovering_text": null,
        "discovered_text_template": null
      },
      "supported_model_types": ["llm", "vision", "image"],
      "llm_workflow": "openai_chat_completions",
      "runtime_capability": {
        "transport_type": "openai_compatible",
        "api_family": "openai_chat_completions",
        "default_privacy_level": "public_cloud",
        "default_supported_capabilities": ["text", "vision", "image_generation"]
      }
    }
  },
  "compatibility": {
    "provider_profile_schema_version": 1,
    "transport_type": "openai_compatible",
    "api_family": "openai_chat_completions",
    "description": "Aggregator for multiple upstream models with a few provider-specific headers."
  }
}
