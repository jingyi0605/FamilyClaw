{
  "id": "health-basic-reader",
  "name": "健康基础数据插件",
  "version": "0.1.0",
  "api_version": 1,
  "types": ["integration"],
  "permissions": [
    "health.read",
    "memory.write.observation"
  ],
  "risk_level": "low",
  "triggers": ["manual", "schedule"],
  "entrypoints": {
    "integration": "app.plugins.builtin.health_basic.integration.sync"
  },
  "capabilities": {
    "integration": {
      "domains": ["health"],
      "instance_model": "single_instance",
      "refresh_mode": "polling",
      "supports_discovery": false,
      "supports_actions": false,
      "supports_cards": true,
      "entity_types": ["health.steps", "health.sleep", "health.heart_rate"],
      "default_cache_ttl_seconds": 1800,
      "max_stale_seconds": 21600
    }
  },
  "dashboard_cards": [
    {
      "card_key": "daily-steps-summary",
      "placement": "home",
      "template_type": "metric",
      "size": "half",
      "title_key": "plugin.health_basic.dashboard.daily_steps.title",
      "subtitle_key": "plugin.health_basic.dashboard.daily_steps.subtitle",
      "empty_state_key": "plugin.health_basic.dashboard.daily_steps.empty",
      "refresh_strategy": "scheduled",
      "allowed_actions": [
        "open_plugin_detail"
      ]
    }
  ]
}

