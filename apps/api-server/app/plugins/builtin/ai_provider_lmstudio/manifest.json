{
  "id": "builtin.provider.lmstudio",
  "name": "LM Studio",
  "version": "1.0.0",
  "types": ["ai-provider"],
  "permissions": [],
  "risk_level": "low",
  "triggers": [],
  "entrypoints": {
    "ai_provider": "app.plugins.builtin.ai_provider_lmstudio.driver.build_driver"
  },
  "capabilities": {
    "ai_provider": {
      "adapter_code": "lmstudio",
      "display_name": "LM Studio",
      "field_schema": [
        { "key": "display_name", "label": "Display Name", "field_type": "text", "required": true, "placeholder": "LM Studio Main", "options": [] },
        { "key": "provider_code", "label": "Provider Code", "field_type": "text", "required": true, "placeholder": "family-lmstudio-main", "options": [] },
        { "key": "base_url", "label": "Base URL", "field_type": "text", "required": false, "placeholder": "http://127.0.0.1:1234/v1", "help_text": "默认本地服务地址是 http://localhost:1234/v1。", "default_value": "http://127.0.0.1:1234/v1", "options": [] },
        { "key": "secret_ref", "label": "Secret Reference", "field_type": "secret", "required": false, "placeholder": "LM_STUDIO_API_KEY", "help_text": "LM Studio 默认不校验 API Key；只有你显式开启 token 保护时才需要填写。", "options": [] },
        { "key": "model_name", "label": "Model Name", "field_type": "text", "required": true, "placeholder": "qwen2.5-7b-instruct", "options": [] },
        {
          "key": "privacy_level",
          "label": "Privacy Level",
          "field_type": "select",
          "required": true,
          "default_value": "local_only",
          "options": [
            { "label": "Local Only", "value": "local_only" }
          ]
        },
        { "key": "latency_budget_ms", "label": "Latency Budget (ms)", "field_type": "number", "required": false, "placeholder": "60000", "default_value": 60000, "options": [] }
      ],
      "supported_model_types": ["llm"],
      "llm_workflow": "openai_chat_completions",
      "runtime_capability": {
        "transport_type": "local_gateway",
        "api_family": "openai_chat_completions",
        "default_privacy_level": "local_only",
        "default_supported_capabilities": ["text"],
        "supports_model_discovery": true
      }
    }
  },
  "compatibility": {
    "provider_profile_schema_version": 1,
    "transport_type": "local_gateway",
    "api_family": "openai_chat_completions",
    "description": "本地 LM Studio 服务，直接走 OpenAI 兼容接口，并自动读取当前已加载模型。"
  }
}
