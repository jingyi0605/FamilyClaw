{
  "id": "channel-wecom-app",
  "name": "企业微信自建应用通道",
  "version": "0.1.0",
  "types": ["channel"],
  "permissions": [
    "channel.receive",
    "channel.send"
  ],
  "risk_level": "low",
  "triggers": ["manual"],
  "entrypoints": {
    "channel": "app.plugins.builtin.channel_wecom_app.channel.handle"
  },
  "config_specs": [
    {
      "scope_type": "channel_account",
      "title": "企业微信自建应用配置",
      "description": "给当前企业微信自建应用填回调和发信参数。",
      "schema_version": 1,
      "config_schema": {
        "fields": [
          {
            "key": "corp_id",
            "label": "Corp ID",
            "type": "string",
            "required": true
          },
          {
            "key": "corp_secret",
            "label": "Corp Secret",
            "type": "secret",
            "required": true
          },
          {
            "key": "agent_id",
            "label": "Agent ID",
            "type": "string",
            "required": true
          },
          {
            "key": "callback_token",
            "label": "Callback Token",
            "type": "secret",
            "required": true
          },
          {
            "key": "encoding_aes_key",
            "label": "Encoding AES Key",
            "type": "secret",
            "required": true
          }
        ]
      },
      "ui_schema": {
        "sections": [
          {
            "id": "basic",
            "title": "连接参数",
            "fields": ["corp_id", "corp_secret", "agent_id", "callback_token", "encoding_aes_key"]
          }
        ],
        "field_order": ["corp_id", "corp_secret", "agent_id", "callback_token", "encoding_aes_key"],
        "submit_text": "保存配置",
        "widgets": {
          "corp_id": {
            "widget": "input",
            "placeholder": "ww1234567890abcdef",
            "help_text": "企业微信 Corp ID。"
          },
          "corp_secret": {
            "widget": "password",
            "placeholder": "应用 Secret",
            "help_text": "企业微信应用 Secret。"
          },
          "agent_id": {
            "widget": "input",
            "placeholder": "1000001",
            "help_text": "企业微信应用 AgentId。"
          },
          "callback_token": {
            "widget": "password",
            "placeholder": "回调 Token",
            "help_text": "企业微信回调校验 Token。"
          },
          "encoding_aes_key": {
            "widget": "password",
            "placeholder": "消息加解密密钥",
            "help_text": "企业微信消息加解密使用的 AES Key。"
          }
        }
      }
    }
  ],
  "capabilities": {
    "channel": {
      "platform_code": "wecom-app",
      "inbound_modes": ["webhook"],
      "delivery_modes": ["reply", "push"],
      "supports_member_binding": true,
      "supports_group_chat": false,
      "supports_threading": false,
      "ui": {
        "binding": {
          "identity_label": "企业微信用户 ID",
          "identity_placeholder": "例如：zhangsan",
          "identity_help_text": "企业微信回调里的用户标识。",
          "chat_label": "会话 ID",
          "chat_placeholder": "例如：direct:zhangsan",
          "chat_help_text": "如果需要排查会话映射，可以记录回调中的会话标识。",
          "candidate_title": "待绑定企业微信用户",
          "candidate_help_text": "这里只展示最近给当前账号发过消息、但还没有在当前账号下绑定的用户。"
        }
      },
      "reserved": false
    }
  }
}
