{
  "id": "builtin.provider.localai",
  "name": "LocalAI",
  "version": "1.0.0",
  "types": ["ai-provider"],
  "permissions": [],
  "risk_level": "low",
  "triggers": [],
  "entrypoints": {
    "ai_provider": "app.plugins.builtin.ai_provider_localai.driver.build_driver"
  },
  "capabilities": {
    "ai_provider": {
      "adapter_code": "localai",
      "display_name": "LocalAI",
      "field_schema": [
        { "key": "display_name", "label": "Display Name", "field_type": "text", "required": true, "placeholder": "LocalAI Main", "options": [] },
        { "key": "provider_code", "label": "Provider Code", "field_type": "text", "required": true, "placeholder": "family-localai-main", "options": [] },
        { "key": "base_url", "label": "Base URL", "field_type": "text", "required": false, "placeholder": "http://127.0.0.1:8080/v1", "help_text": "默认本地服务地址是 http://localhost:8080/v1。", "default_value": "http://127.0.0.1:8080/v1", "options": [] },
        { "key": "secret_ref", "label": "Secret Reference", "field_type": "secret", "required": false, "placeholder": "LOCALAI_API_KEY", "help_text": "只有你在 LocalAI 里主动开启 API Key 校验时才需要填写。", "options": [] },
        { "key": "model_name", "label": "Model Name", "field_type": "text", "required": true, "placeholder": "local-model", "options": [] },
        {
          "key": "privacy_level",
          "label": "Privacy Level",
          "field_type": "select",
          "required": true,
          "default_value": "local_only",
          "options": [
            { "label": "Local Only", "value": "local_only" }
          ]
        },
        { "key": "latency_budget_ms", "label": "Latency Budget (ms)", "field_type": "number", "required": false, "placeholder": "60000", "default_value": 60000, "options": [] }
      ],
      "supported_model_types": ["llm"],
      "llm_workflow": "openai_chat_completions",
      "runtime_capability": {
        "transport_type": "local_gateway",
        "api_family": "openai_chat_completions",
        "default_privacy_level": "local_only",
        "default_supported_capabilities": ["text"],
        "supports_model_discovery": true
      }
    }
  },
  "compatibility": {
    "provider_profile_schema_version": 1,
    "transport_type": "local_gateway",
    "api_family": "openai_chat_completions",
    "description": "本地 LocalAI 服务，使用 OpenAI 兼容接口，并自动发现当前可用模型。"
  }
}
