{
  "id": "homeassistant-device-sync",
  "name": "HomeAssistant 设备同步插件",
  "version": "0.1.0",
  "types": ["connector", "memory-ingestor"],
  "permissions": [
    "device.read",
    "memory.write.device",
    "memory.write.observation"
  ],
  "risk_level": "low",
  "triggers": ["manual", "schedule"],
  "entrypoints": {
    "connector": "app.plugins.builtin.homeassistant_device_sync.connector.sync",
    "memory_ingestor": "app.plugins.builtin.homeassistant_device_sync.ingestor.transform"
  }
}
